{
  "$schema": "https://schema.management.azure.com/schemas/2018-05-01/subscriptionDeploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.44.1.10279",
      "templateHash": "13888927169701544145"
    }
  },
  "parameters": {
    "environmentName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "location": {
      "type": "string",
      "defaultValue": "[deployment().location]"
    },
    "adminPassword": {
      "type": "securestring"
    },
    "databaseUrl": {
      "type": "securestring",
      "defaultValue": ""
    },
    "sqliteUseAzureFiles": {
      "type": "bool",
      "defaultValue": false
    }
  },
  "variables": {
    "normalizedEnvironmentName": "[toLower(replace(parameters('environmentName'), '_', '-'))]",
    "tags": {
      "azd-env-name": "[parameters('environmentName')]"
    }
  },
  "resources": [
    {
      "type": "Microsoft.Resources/resourceGroups",
      "apiVersion": "2024-03-01",
      "name": "[format('rg-{0}', variables('normalizedEnvironmentName'))]",
      "location": "[parameters('location')]",
      "tags": "[variables('tags')]"
    },
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "quiz-app-resources",
      "resourceGroup": "[format('rg-{0}', variables('normalizedEnvironmentName'))]",
      "properties": {
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "mode": "Incremental",
        "parameters": {
          "adminPassword": {
            "value": "[parameters('adminPassword')]"
          },
          "databaseUrl": {
            "value": "[parameters('databaseUrl')]"
          },
          "sqliteUseAzureFiles": {
            "value": "[parameters('sqliteUseAzureFiles')]"
          },
          "name": {
            "value": "[variables('normalizedEnvironmentName')]"
          },
          "location": {
            "value": "[parameters('location')]"
          },
          "tags": {
            "value": "[variables('tags')]"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.44.1.10279",
              "templateHash": "9902786232590242833"
            }
          },
          "parameters": {
            "name": {
              "type": "string"
            },
            "location": {
              "type": "string",
              "defaultValue": "[resourceGroup().location]"
            },
            "tags": {
              "type": "object",
              "defaultValue": {}
            },
            "adminPassword": {
              "type": "securestring"
            },
            "databaseUrl": {
              "type": "securestring",
              "defaultValue": ""
            },
            "sqliteUseAzureFiles": {
              "type": "bool",
              "defaultValue": false
            }
          },
          "variables": {
            "serviceName": "web",
            "uniqueToken": "[take(uniqueString(subscription().id, resourceGroup().id, parameters('name')), 12)]",
            "containerAppName": "[format('ca-{0}-{1}', take(parameters('name'), 20), take(variables('uniqueToken'), 6))]",
            "managedEnvironmentName": "[format('cae-{0}', parameters('name'))]",
            "logAnalyticsWorkspaceName": "[format('log-{0}', parameters('name'))]",
            "applicationInsightsName": "[format('appi-{0}', parameters('name'))]",
            "containerRegistryName": "[format('cr{0}', variables('uniqueToken'))]",
            "containerAppIdentityName": "[format('id-{0}', parameters('name'))]",
            "storageAccountName": "[format('st{0}', variables('uniqueToken'))]",
            "fileShareName": "quiz-data",
            "environmentStorageName": "quiz-data",
            "sqliteDataPath": "/app/data",
            "usePostgres": "[not(empty(parameters('databaseUrl')))]",
            "useAzureFilesForSqlite": "[and(not(variables('usePostgres')), parameters('sqliteUseAzureFiles'))]",
            "placeholderImage": "mcr.microsoft.com/azuredocs/containerapps-helloworld:latest"
          },
          "resources": [
            {
              "type": "Microsoft.OperationalInsights/workspaces",
              "apiVersion": "2023-09-01",
              "name": "[variables('logAnalyticsWorkspaceName')]",
              "location": "[parameters('location')]",
              "tags": "[parameters('tags')]",
              "properties": {
                "sku": {
                  "name": "PerGB2018"
                },
                "retentionInDays": 30
              }
            },
            {
              "type": "Microsoft.Insights/components",
              "apiVersion": "2020-02-02",
              "name": "[variables('applicationInsightsName')]",
              "location": "[parameters('location')]",
              "kind": "web",
              "tags": "[parameters('tags')]",
              "properties": {
                "Application_Type": "web",
                "WorkspaceResourceId": "[resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsWorkspaceName'))]"
              },
              "dependsOn": [
                "[resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsWorkspaceName'))]"
              ]
            },
            {
              "type": "Microsoft.ContainerRegistry/registries",
              "apiVersion": "2023-07-01",
              "name": "[variables('containerRegistryName')]",
              "location": "[parameters('location')]",
              "tags": "[parameters('tags')]",
              "sku": {
                "name": "Basic"
              },
              "properties": {
                "adminUserEnabled": false
              }
            },
            {
              "type": "Microsoft.ManagedIdentity/userAssignedIdentities",
              "apiVersion": "2023-01-31",
              "name": "[variables('containerAppIdentityName')]",
              "location": "[parameters('location')]",
              "tags": "[parameters('tags')]"
            },
            {
              "condition": "[variables('useAzureFilesForSqlite')]",
              "type": "Microsoft.Storage/storageAccounts",
              "apiVersion": "2023-05-01",
              "name": "[variables('storageAccountName')]",
              "location": "[parameters('location')]",
              "tags": "[parameters('tags')]",
              "sku": {
                "name": "Standard_LRS"
              },
              "kind": "StorageV2",
              "properties": {
                "allowSharedKeyAccess": true,
                "accessTier": "Hot",
                "allowBlobPublicAccess": false,
                "minimumTlsVersion": "TLS1_2",
                "supportsHttpsTrafficOnly": true
              }
            },
            {
              "condition": "[variables('useAzureFilesForSqlite')]",
              "type": "Microsoft.Storage/storageAccounts/fileServices",
              "apiVersion": "2023-05-01",
              "name": "[format('{0}/{1}', variables('storageAccountName'), 'default')]",
              "dependsOn": [
                "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName'))]"
              ]
            },
            {
              "condition": "[variables('useAzureFilesForSqlite')]",
              "type": "Microsoft.Storage/storageAccounts/fileServices/shares",
              "apiVersion": "2023-05-01",
              "name": "[format('{0}/{1}/{2}', variables('storageAccountName'), 'default', variables('fileShareName'))]",
              "properties": {
                "shareQuota": 10
              },
              "dependsOn": [
                "[resourceId('Microsoft.Storage/storageAccounts/fileServices', variables('storageAccountName'), 'default')]"
              ]
            },
            {
              "type": "Microsoft.App/managedEnvironments",
              "apiVersion": "2024-03-01",
              "name": "[variables('managedEnvironmentName')]",
              "location": "[parameters('location')]",
              "tags": "[parameters('tags')]",
              "properties": {
                "appLogsConfiguration": {
                  "destination": "log-analytics",
                  "logAnalyticsConfiguration": {
                    "customerId": "[reference(resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsWorkspaceName')), '2023-09-01').customerId]",
                    "sharedKey": "[listKeys(resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsWorkspaceName')), '2023-09-01').primarySharedKey]"
                  }
                }
              },
              "dependsOn": [
                "[resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsWorkspaceName'))]"
              ]
            },
            {
              "condition": "[variables('useAzureFilesForSqlite')]",
              "type": "Microsoft.App/managedEnvironments/storages",
              "apiVersion": "2024-03-01",
              "name": "[format('{0}/{1}', variables('managedEnvironmentName'), variables('environmentStorageName'))]",
              "properties": {
                "azureFile": {
                  "accountName": "[variables('storageAccountName')]",
                  "accountKey": "[listKeys(resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName')), '2023-05-01').keys[0].value]",
                  "shareName": "[variables('fileShareName')]",
                  "accessMode": "ReadWrite"
                }
              },
              "dependsOn": [
                "[resourceId('Microsoft.App/managedEnvironments', variables('managedEnvironmentName'))]",
                "[resourceId('Microsoft.Storage/storageAccounts/fileServices/shares', variables('storageAccountName'), 'default', variables('fileShareName'))]",
                "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName'))]"
              ]
            },
            {
              "type": "Microsoft.App/containerApps",
              "apiVersion": "2024-03-01",
              "name": "[variables('containerAppName')]",
              "location": "[parameters('location')]",
              "tags": "[union(parameters('tags'), createObject('azd-service-name', variables('serviceName')))]",
              "identity": {
                "type": "SystemAssigned,UserAssigned",
                "userAssignedIdentities": {
                  "[format('{0}', resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('containerAppIdentityName')))]": {}
                }
              },
              "properties": {
                "managedEnvironmentId": "[resourceId('Microsoft.App/managedEnvironments', variables('managedEnvironmentName'))]",
                "configuration": {
                  "activeRevisionsMode": "Single",
                  "registries": [
                    {
                      "server": "[reference(resourceId('Microsoft.ContainerRegistry/registries', variables('containerRegistryName')), '2023-07-01').loginServer]",
                      "identity": "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('containerAppIdentityName'))]"
                    }
                  ],
                  "ingress": {
                    "external": true,
                    "targetPort": 3000,
                    "transport": "auto",
                    "allowInsecure": false
                  },
                  "secrets": "[concat(if(variables('usePostgres'), createArray(createObject('name', 'database-url', 'value', parameters('databaseUrl'))), createArray()), createArray(createObject('name', 'admin-password', 'value', parameters('adminPassword')), createObject('name', 'applicationinsights-connection-string', 'value', reference(resourceId('Microsoft.Insights/components', variables('applicationInsightsName')), '2020-02-02').ConnectionString)))]"
                },
                "template": {
                  "scale": {
                    "minReplicas": 1,
                    "maxReplicas": "[if(variables('usePostgres'), 3, 1)]",
                    "rules": [
                      {
                        "name": "http-scale",
                        "http": {
                          "metadata": {
                            "concurrentRequests": "100"
                          }
                        }
                      }
                    ]
                  },
                  "containers": [
                    {
                      "name": "[variables('serviceName')]",
                      "image": "[variables('placeholderImage')]",
                      "env": "[concat(createArray(createObject('name', 'NODE_ENV', 'value', 'production'), createObject('name', 'PORT', 'value', '3000'), createObject('name', 'ADMIN_PASSWORD', 'secretRef', 'admin-password'), createObject('name', 'APPLICATIONINSIGHTS_CONNECTION_STRING', 'secretRef', 'applicationinsights-connection-string')), concat(if(variables('usePostgres'), createArray(createObject('name', 'DATABASE_URL', 'secretRef', 'database-url')), createArray()), if(not(variables('usePostgres')), createArray(createObject('name', 'DATABASE_PATH', 'value', format('{0}/quiz.sqlite', variables('sqliteDataPath')))), createArray())))]",
                      "volumeMounts": "[if(variables('useAzureFilesForSqlite'), createArray(createObject('volumeName', variables('environmentStorageName'), 'mountPath', variables('sqliteDataPath'))), createArray())]",
                      "probes": [
                        {
                          "type": "Liveness",
                          "httpGet": {
                            "path": "/health",
                            "port": 3000
                          },
                          "initialDelaySeconds": 20,
                          "periodSeconds": 30
                        },
                        {
                          "type": "Readiness",
                          "httpGet": {
                            "path": "/health",
                            "port": 3000
                          },
                          "initialDelaySeconds": 10,
                          "periodSeconds": 10
                        }
                      ],
                      "resources": {
                        "cpu": "[json('0.5')]",
                        "memory": "1Gi"
                      }
                    }
                  ],
                  "volumes": "[if(variables('useAzureFilesForSqlite'), createArray(createObject('name', variables('environmentStorageName'), 'storageType', 'AzureFile', 'storageName', variables('environmentStorageName'))), createArray())]"
                }
              },
              "dependsOn": [
                "[extensionResourceId(resourceId('Microsoft.ContainerRegistry/registries', variables('containerRegistryName')), 'Microsoft.Authorization/roleAssignments', guid(resourceId('Microsoft.ContainerRegistry/registries', variables('containerRegistryName')), resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('containerAppIdentityName')), 'acrpull'))]",
                "[resourceId('Microsoft.Insights/components', variables('applicationInsightsName'))]",
                "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('containerAppIdentityName'))]",
                "[resourceId('Microsoft.App/managedEnvironments', variables('managedEnvironmentName'))]",
                "[resourceId('Microsoft.App/managedEnvironments/storages', variables('managedEnvironmentName'), variables('environmentStorageName'))]",
                "[resourceId('Microsoft.ContainerRegistry/registries', variables('containerRegistryName'))]"
              ]
            },
            {
              "type": "Microsoft.Authorization/roleAssignments",
              "apiVersion": "2022-04-01",
              "scope": "[resourceId('Microsoft.ContainerRegistry/registries', variables('containerRegistryName'))]",
              "name": "[guid(resourceId('Microsoft.ContainerRegistry/registries', variables('containerRegistryName')), resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('containerAppIdentityName')), 'acrpull')]",
              "properties": {
                "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '7f951dda-4ed3-4680-a7ca-43fe172d538d')]",
                "principalId": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('containerAppIdentityName')), '2023-01-31').principalId]",
                "principalType": "ServicePrincipal"
              },
              "dependsOn": [
                "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('containerAppIdentityName'))]",
                "[resourceId('Microsoft.ContainerRegistry/registries', variables('containerRegistryName'))]"
              ]
            }
          ],
          "outputs": {
            "containerRegistryEndpoint": {
              "type": "string",
              "value": "[reference(resourceId('Microsoft.ContainerRegistry/registries', variables('containerRegistryName')), '2023-07-01').loginServer]"
            },
            "webUrl": {
              "type": "string",
              "value": "[format('https://{0}', reference(resourceId('Microsoft.App/containerApps', variables('containerAppName')), '2024-03-01').configuration.ingress.fqdn)]"
            }
          }
        }
      },
      "dependsOn": [
        "[subscriptionResourceId('Microsoft.Resources/resourceGroups', format('rg-{0}', variables('normalizedEnvironmentName')))]"
      ]
    }
  ],
  "outputs": {
    "AZURE_RESOURCE_GROUP": {
      "type": "string",
      "value": "[format('rg-{0}', variables('normalizedEnvironmentName'))]"
    },
    "AZURE_CONTAINER_REGISTRY_ENDPOINT": {
      "type": "string",
      "value": "[reference(extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, format('rg-{0}', variables('normalizedEnvironmentName'))), 'Microsoft.Resources/deployments', 'quiz-app-resources'), '2025-04-01').outputs.containerRegistryEndpoint.value]"
    },
    "WEB_URL": {
      "type": "string",
      "value": "[reference(extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, format('rg-{0}', variables('normalizedEnvironmentName'))), 'Microsoft.Resources/deployments', 'quiz-app-resources'), '2025-04-01').outputs.webUrl.value]"
    }
  }
}